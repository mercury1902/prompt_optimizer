# ============================================================
# ClaudeKit Chat - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git - it contains sensitive data!
# ============================================================

# ------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------
# Option 1: SQLite (Recommended for local development)
DATABASE_URL=sqlite://./data/chat.db

# Option 2: PostgreSQL (For production)
# DATABASE_URL=postgresql://username:password@localhost:5432/claudekit_chatbot

# ------------------------------------------------------------
# Fireworks AI API Configuration (REQUIRED)
# Get your API key from: https://fireworks.ai/api-keys
# ------------------------------------------------------------
# Server-side API key (for prompt optimizer)
FIREPASS_API_KEY=your_fireworks_api_key_here

# Client-side API key (for chat functionality)
PUBLIC_FIREPASS_API_KEY=your_fireworks_api_key_here

# Model configuration
PUBLIC_FIREPASS_MODEL=accounts/fireworks/routers/kimi-k2p5-turbo
PUBLIC_FIREPASS_BASE_URL=https://api.fireworks.ai/inference/v1

# ------------------------------------------------------------
# Session Management (Optional)
# ------------------------------------------------------------
MAX_SESSIONS=100
MESSAGE_PAGE_SIZE=50

# ------------------------------------------------------------
# Feature Flags (Optional)
# ------------------------------------------------------------
# Enable tool execution (Tavily, E2B) - Phase 4 feature
ENABLE_TOOLS=true

# Enable SSE streaming for real-time responses
ENABLE_STREAMING=true

# ------------------------------------------------------------
# Benchmark Configuration (Optional)
# ------------------------------------------------------------
# Set to 1 to run live API benchmarks (costs API credits)
RUN_LIVE_BENCHMARK=0
