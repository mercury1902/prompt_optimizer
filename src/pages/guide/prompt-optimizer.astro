---
import Layout from '../../layouts/Layout.astro';
import { PromptOptimizerChat } from '../../components/command-guide/prompt-optimizer-chat';
import { Sparkles, ArrowLeft, Zap } from 'lucide-react';
---

<Layout title="Prompt Optimizer" description="Tối ưu hóa prompt với AI - biến prompt thô thành prompt chuyên nghiệp">
  <main class="min-h-screen">
    <section class="py-8 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        {/* Back Link */}
        <a
          href="/guide/"
          class="inline-flex items-center gap-2 text-white/50 hover:text-white transition-colors mb-6"
        >
          <ArrowLeft className="w-4 h-4" />
          Quay lại Command Guide
        </a>

        {/* Header */}
        <div class="flex items-center gap-4 mb-6">
          <div class="p-3 rounded-xl bg-purple-400/20 text-purple-300">
            <Sparkles className="w-8 h-8" />
          </div>
          <div>
            <h1 class="text-3xl font-bold text-white">Prompt Optimizer</h1>
            <p class="text-white/60">Biến prompt thô thành prompt chuyên nghiệp cho vibe coding</p>
          </div>
        </div>

        {/* Features */}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
          <div class="flex items-center gap-3 p-4 rounded-xl bg-white/5 border border-white/10">
            <div class="p-2 rounded-lg bg-brand-400/20 text-brand-300">
              <Zap className="w-5 h-5" />
            </div>
            <div>
              <p class="font-medium text-white">Tối ưu tức thì</p>
              <p class="text-sm text-white/50">AI phân tích và cải thiện prompt ngay</p>
            </div>
          </div>
          <div class="flex items-center gap-3 p-4 rounded-xl bg-white/5 border border-white/10">
            <div class="p-2 rounded-lg bg-blue-400/20 text-blue-300">
              <Sparkles className="w-5 h-5" />
            </div>
            <div>
              <p class="font-medium text-white">Gợi ý command</p>
              <p class="text-sm text-white/50">Đề xuất command phù hợp cho prompt</p>
            </div>
          </div>
          <div class="flex items-center gap-3 p-4 rounded-xl bg-white/5 border border-white/10">
            <div class="p-2 rounded-lg bg-green-400/20 text-green-300">
              <Zap className="w-5 h-5" />
            </div>
            <div>
              <p class="font-medium text-white">Vibe coding ready</p>
              <p class="text-sm text-white/50">Prompt chuẩn cho Claude Code</p>
            </div>
          </div>
        </div>

        {/* Chat Interface */}
        <PromptOptimizerChat client:load />
      </div>
    </section>
  </main>
</Layout>
