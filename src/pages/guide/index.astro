---
import Layout from '../../layouts/Layout.astro';
import { DecisionTreeWithRecommendations } from '../../components/command-guide/decision-tree-with-recommendations';
import { CommandBrowserWithSearch } from '../../components/command-guide/command-browser-with-search';
import { Sparkles, BookOpen, Lightbulb } from 'lucide-react';
---

<Layout title="Command Guide" description="Hướng dẫn sử dụng Claude Code commands">
  <main class="min-h-screen">
    {/* Hero Section */}
    <section class="relative py-16 px-4 sm:px-6 lg:px-8">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-400/10 border border-brand-400/30 mb-6">
            <Sparkles className="w-5 h-5 text-brand-400" />
            <span class="text-brand-200 font-medium">ClaudeKit Command Guide</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
            Chọn đúng command cho<br />
            <span class="text-brand-400">mọi tình huống</span>
          </h1>
          <p class="text-xl text-white/60 max-w-2xl mx-auto">
            Không còn bối rối khi dùng Claude Code. Decision tree giúp bạn tìm command phù hợp,
            và prompt optimizer giúp viết prompt chuyên nghiệp.
          </p>
        </div>

        {/* Quick Links */}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
          <a
            href="/guide/"
            class="flex items-center gap-4 p-6 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md hover:bg-white/10 hover:border-brand-400/30 transition-all group"
          >
            <div class="p-3 rounded-xl bg-brand-400/20 text-brand-300 group-hover:bg-brand-400/30">
              <Lightbulb className="w-6 h-6" />
            </div>
            <div>
              <h3 class="font-semibold text-white">Decision Tree</h3>
              <p class="text-sm text-white/50">Tìm command phù hợp</p>
            </div>
          </a>

          <a
            href="/guide/commands"
            class="flex items-center gap-4 p-6 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md hover:bg-white/10 hover:border-brand-400/30 transition-all group"
          >
            <div class="p-3 rounded-xl bg-blue-400/20 text-blue-300 group-hover:bg-blue-400/30">
              <BookOpen className="w-6 h-6" />
            </div>
            <div>
              <h3 class="font-semibold text-white">Command Browser</h3>
              <p class="text-sm text-white/50">Xem tất cả commands</p>
            </div>
          </a>

          <a
            href="/guide/prompt-optimizer"
            class="flex items-center gap-4 p-6 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md hover:bg-white/10 hover:border-brand-400/30 transition-all group"
          >
            <div class="p-3 rounded-xl bg-purple-400/20 text-purple-300 group-hover:bg-purple-400/30">
              <Sparkles className="w-6 h-6" />
            </div>
            <div>
              <h3 class="font-semibold text-white">Prompt Optimizer</h3>
              <p class="text-sm text-white/50">Tối ưu prompt với AI</p>
            </div>
          </a>
        </div>

        {/* Decision Tree Section */}
        <div class="mb-8">
          <DecisionTreeWithRecommendations client:load />
        </div>
      </div>
    </section>
  </main>
</Layout>
