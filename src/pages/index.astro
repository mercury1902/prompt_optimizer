---
import Layout from '../layouts/Layout.astro';
import ChatFrameWithGlassmorphismAndVietnamese from '../components/chat/chat-frame-with-glassmorphism-and-vietnamese';
import { BookOpen, MessageSquare } from 'lucide-react';
---

<Layout>
  {/* Navigation Header */}
  <header class="fixed top-0 left-0 right-0 z-50 px-4 py-3">
    <div class="max-w-6xl mx-auto">
      <nav class="flex items-center justify-between px-4 py-2 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-xl">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-lg bg-brand-400/20 flex items-center justify-center">
            <span class="text-brand-300 font-bold text-sm">CK</span>
          </div>
          <span class="font-semibold text-white">ClaudeKit</span>
        </div>
        <div class="flex items-center gap-2">
          <a
            href="/guide/"
            class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm text-white/70 hover:text-white hover:bg-white/10 transition-all"
          >
            <BookOpen class="w-4 h-4" />
            <span class="hidden sm:inline">Command Guide</span>
          </a>
          <a
            href="/guide/prompt-optimizer"
            class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm bg-brand-400/20 text-brand-200 hover:bg-brand-400/30 transition-all"
          >
            <MessageSquare class="w-4 h-4" />
            <span class="hidden sm:inline">Prompt Optimizer</span>
          </a>
        </div>
      </nav>
    </div>
  </header>

  {/* Spacer for fixed header */}
  <div class="h-16"></div>

  <ChatFrameWithGlassmorphismAndVietnamese client:load />
</Layout>
